{
  "name": "reserveflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @reserveflow/web dev",
    "build": "pnpm --filter @reserveflow/web build",
    "start": "pnpm --filter @reserveflow/web start",
    "lint": "pnpm --filter @reserveflow/web lint",
    "typecheck": "pnpm --filter @reserveflow/web typecheck",
    "test": "pnpm --filter @reserveflow/web test",
    "test:e2e": "pnpm --filter @reserveflow/web test:e2e",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "create:new": "powershell.exe -ExecutionPolicy Bypass -NoProfile -File ./scripts/create-new-project.ps1",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "next": "16.2.6"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prisma": "^7.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}
